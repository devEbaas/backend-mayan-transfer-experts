# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173
# Used to build Stripe Checkout success_url/cancel_url
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mayan_transfer_experts?schema=public"
# Direct (non-pooled) connection, used by Prisma for migrations
DIRECT_URL="postgresql://user:password@localhost:5432/mayan_transfer_experts?schema=public"

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# Logging
LOG_LEVEL=debug

# Payments — Stripe
STRIPE_SECRET_KEY=sk_test_xxx
# Signing secret for the /payments/stripe/webhook endpoint (from the Stripe Dashboard or `stripe listen`)
STRIPE_WEBHOOK_SECRET=whsec_xxx
